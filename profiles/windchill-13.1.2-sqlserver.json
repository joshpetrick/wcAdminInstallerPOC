{
  "profileId": "windchill-13.1.2-foundation-sqlserver",
  "displayName": "Windchill 13.1.2.0 Foundation POC - SQL Server 2022 Developer",
  "windchillVersion": "13.1.2.0",
  "compatibilityStatus": "POC_NOT_CERTIFIED",
  "provider": "virtualbox",
  "artifactVersion": "0.1.0",
  "baseOperatingSystem": {
    "distribution": "AlmaLinux",
    "majorVersion": "9",
    "minimumMinorVersion": 6,
    "allowLaterMinorVersions": true,
    "vagrantBox": "almalinux/9",
    "vagrantBoxVersion": ""
  },
  "vm": {
    "name": "wc131-foundation-sqlserver-build",
    "hostname": "wc131-sql-foundation",
    "cpus": 6,
    "memoryMb": 12288,
    "primaryDiskGb": 250,
    "headless": true
  },
  "java": {
    "vendor": "Amazon Corretto",
    "majorVersion": 21,
    "installationDirectory": "/opt/java",
    "javaHomeSymlink": "/opt/java/current",
    "downloadAutomatically": true
  },
  "database": {
    "provider": "SQLSERVER",
    "profileId": "sqlserver-2022-developer-linux",
    "sqlServer": {
      "majorVersion": "2022",
      "edition": "Developer",
      "installationSource": "MICROSOFT_PACKAGE_REPOSITORY",
      "repositoryPlatform": "rhel",
      "repositoryMajorVersion": 9,
      "packageVersionPolicy": "LATEST_AVAILABLE",
      "pinnedPackageVersion": "",
      "minimumProductVersion": "16.0.4100.1",
      "port": 1433,
      "enableAgent": true,
      "enableContainedDatabaseAuthentication": true,
      "createWindchillDatabase": false,
      "maxMemoryMb": 4096,
      "dataDirectory": "/var/opt/mssql/data",
      "logDirectory": "/var/opt/mssql/log",
      "backupDirectory": "/var/opt/mssql/backup"
    }
  },
  "paths": {
    "defaultHostRoot": "C:\\WindchillFoundationPOC",
    "mediaDirectory": "C:\\WindchillFoundationPOC\\Media",
    "cacheDirectory": "C:\\WindchillFoundationPOC\\Cache",
    "buildDirectory": "C:\\WindchillFoundationPOC\\Builds",
    "outputDirectory": "C:\\WindchillFoundationPOC\\Output",
    "mockRepositoryDirectory": "C:\\WindchillFoundationPOC\\MockYDrive"
  }
}
